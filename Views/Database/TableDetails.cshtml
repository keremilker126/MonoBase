@using System.Text.Json
@model List<MonoBase.Models.DynamicEntry>

@{
    ViewData["Title"] = ViewBag.TableName;

    var tableName = ViewBag.TableName;
    var tableId = ViewBag.TableId;
}
@{
    tableName = ViewBag.TableName;
    
    // 1. ADIM: Tüm satırlardaki benzersiz JSON anahtarlarını topla (Tablo başlıkları için)
    var allKeys = new HashSet<string>();
    var deserializedRows = new List<Dictionary<string, JsonElement>>();
    foreach (var item in Model)
    {
        if (!string.IsNullOrEmpty(item.JsonData.ToString()))
        {
            try
            {
                var dict = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(item.JsonData.ToString());
                if (dict != null)
                {
                    deserializedRows.Add(dict);
                    foreach (var key in dict.Keys) allKeys.Add(key);
                }
            }
            catch { /* Hatalı JSON formatı varsa atla */ }
        }
    }
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    :root {
        --bg: #0b1120;
        --card: #111827;
        --card2: #1e293b;
        --line: #243041;
        --text: #f8fafc;
        --muted: #94a3b8;
        --primary: #2563eb;
        --primaryHover: #1d4ed8;
        --success: #22c55e;
        --danger: #ef4444;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background:
            radial-gradient(circle at top left, #1e3a8a22, transparent 25%),
            radial-gradient(circle at bottom right, #2563eb22, transparent 25%),
            var(--bg);

        font-family: 'Inter', sans-serif;
        color: var(--text);
        min-height: 100vh;
        padding: 40px 0;
    }

    .detail-card {
        background: rgba(17, 24, 39, .88);
        border: 1px solid rgba(255, 255, 255, .05);
        border-radius: 32px;
        padding: 32px;
        backdrop-filter: blur(12px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, .35);
    }

    .btn-back {
        color: var(--muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
        transition: .2s;
        font-weight: 600;
    }

    .btn-back:hover {
        color: white;
        transform: translateX(-4px);
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 28px;
    }

    .table-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .table-sub {
        color: var(--muted);
        font-size: .95rem;
    }

    .btn-primary-modern {
        border: none;
        background: linear-gradient(135deg, var(--primary), #1e40af);
        color: white;
        padding: 14px 24px;
        border-radius: 18px;
        font-weight: 700;
        transition: .2s;
        box-shadow: 0 10px 25px rgba(37, 99, 235, .25);
    }

    .btn-primary-modern:hover {
        transform: translateY(-2px);
    }

    .table-wrapper {
        overflow: auto;
    }

    .table-modern {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 14px;
    }

    .table-modern thead th {
        color: var(--muted);
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 0 20px 10px;
    }

    .table-modern tbody tr {
        background: rgba(255, 255, 255, .03);
        transition: .2s;
    }

    .table-modern tbody tr:hover {
        background: rgba(37, 99, 235, .08);
    }

    .table-modern td {
        padding: 22px;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
    }

    .table-modern td:first-child {
        border-left: 1px solid var(--line);
        border-top-left-radius: 22px;
        border-bottom-left-radius: 22px;
    }

    .table-modern td:last-child {
        border-right: 1px solid var(--line);
        border-top-right-radius: 22px;
        border-bottom-right-radius: 22px;
    }

    .json-code {
        color: #93c5fd;
        font-family: 'Fira Code', 'Courier New', monospace;
        white-space: pre-wrap;
        word-break: break-word;
        margin: 0;
    }

    .btn-icon {
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 14px;
        background: #ffffff10;
        color: white;
        transition: .2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-icon:hover {
        background: #2563eb;
    }

    .btn-delete:hover {
        background: var(--danger);
    }

    .empty-area {
        border: 2px dashed rgba(255, 255, 255, .08);
        border-radius: 28px;
        padding: 70px 20px;
        text-align: center;
    }

    .empty-area i {
        font-size: 3.5rem;
        opacity: .2;
        margin-bottom: 20px;
    }

    .empty-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .empty-sub {
        color: var(--muted);
    }

    /* INLINE EDITOR */

    .inline-editor {
        display: none;
        margin-bottom: 28px;
        background: rgba(15, 23, 42, .92);
        border: 1px solid rgba(255, 255, 255, .06);
        border-radius: 30px;
        overflow: hidden;
        animation: fadeDown .25s ease;
    }

    .inline-editor.active {
        display: block;
    }

    @@keyframes fadeDown {

        from {
            opacity: 0;
            transform: translateY(-15px);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    .inline-editor-header {
        padding: 24px 28px;
        border-bottom: 1px solid rgba(255, 255, 255, .05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .inline-editor-title {
        font-size: 1.2rem;
        font-weight: 800;
    }

    .inline-editor-sub {
        color: var(--muted);
        font-size: .9rem;
        margin-top: 4px;
    }

    .inline-editor-body {
        padding: 28px;
    }

    .inline-editor-footer {
        padding: 24px 28px;
        border-top: 1px solid rgba(255, 255, 255, .05);
    }

    .field-row {
        background: rgba(255, 255, 255, .03);
        border: 1px solid rgba(255, 255, 255, .05);
        border-radius: 22px;
        padding: 18px;
        margin-bottom: 18px;
    }

    .field-label {
        color: var(--muted);
        font-size: .82rem;
        margin-bottom: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 12px;
    }

    .form-modern {
        background: #111827;
        border: 1px solid rgba(255, 255, 255, .07);
        border-radius: 16px;
        color: white;
        padding: 14px;
        width: 100%;
    }

    .form-modern:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, .12);
    }

    .field-remove {
        width: 48px;
        border: none;
        border-radius: 16px;
        background: #ef444422;
        color: #f87171;
        transition: .2s;
    }

    .field-remove:hover {
        background: #ef4444;
        color: white;
    }

    .add-field-btn {
        width: 100%;
        border: 1px dashed rgba(96, 165, 250, .35);
        background: #2563eb11;
        color: #93c5fd;
        padding: 16px;
        border-radius: 18px;
        font-weight: 700;
        transition: .2s;
    }

    .add-field-btn:hover {
        background: #2563eb22;
    }

    .save-btn {
        width: 100%;
        border: none;
        border-radius: 18px;
        padding: 16px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        font-weight: 800;
        transition: .2s;
        box-shadow: 0 10px 25px rgba(37, 99, 235, .25);
    }

    .save-btn:hover {
        transform: translateY(-2px);
    }

    @@media(max-width:768px) {

        .detail-card {
            padding: 22px;
            border-radius: 26px;
        }

        .field-grid {
            grid-template-columns: 1fr;
        }

        .field-remove {
            width: 100%;
            height: 48px;
        }

        .topbar {
            align-items: flex-start;
        }

        .btn-primary-modern {
            width: 100%;
        }
        .table-modern { width: 100%; border-collapse: collapse; margin-top: 20px; }
    .table-modern th { background: var(--card2); color: var(--muted); padding: 12px; text-align: left; font-size: 12px; letter-spacing: 1px; border-bottom: 2px solid var(--line); }
    .table-modern td { padding: 12px; border-bottom: 1px solid var(--line); color: var(--text); font-size: 14px; }
    .text-muted { color: #4b5563; }
    }
</style>

<div class="container">
    <a asp-action="Index" class="btn-back">
        <i class="fa-solid fa-arrow-left-long"></i> Dashboard'a Dön
    </a>

    <div class="detail-card">
        <div class="topbar">
            <div>
                <div class="table-title">@tableName</div>
                <div class="table-sub">
                    <i class="fa-solid fa-database me-1"></i> NoSQL Veri Görünümü
                </div>
            </div>
            <button class="btn-primary-modern" onclick="openEditor()">
                <i class="fa-solid fa-plus me-2"></i> Yeni Veri Ekle
            </button>
        </div>

        @* Editör Paneli (Aynı Kalabilir) *@
        <div class="inline-editor" id="inlineEditor">
            <form asp-action="AddRow" method="post" id="dynamicForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tableName" value="@tableName" />
                <input type="hidden" name="jsonData" id="jsonDataInput" />
                <div class="inline-editor-header">
                    <div class="inline-editor-title">Yeni Doküman Ekle</div>
                    <button type="button" class="btn-icon" onclick="closeEditor()"><i
                        class="fa-solid fa-xmark"></i></button>
                    </div>
                    <div class="inline-editor-body">
                        <div id="fieldsContainer"></div>
                        <button type="button" class="add-field-btn" onclick="addField()"><i
                            class="fa-solid fa-plus me-2"></i>Alan Ekle</button>
                        </div>
                        <div class="inline-editor-footer">
                            <button type="submit" class="save-btn">Kaydet</button>
                        </div>
                    </form>
                </div>

                @if (!Model.Any())
                {
                    <div class="empty-area">
                        <i class="fa-solid fa-box-open"></i>
                        <div class="empty-title">Henüz veri yok</div>
                    </div>
                }
                else
                {
                    <div class="table-wrapper" style="overflow-x: auto;">
    <table class="table-modern">
        <thead>
            <tr>
                @* 1. Sabit ID Kolonu (Her zaman dolu görünür) *@
                <th>SİSTEM ID</th>

                @* 2. Diğer Dinamik Başlıklar (JSON içindeki veriler) *@
                @foreach (var key in allKeys.Where(k => k.ToLower() != "id" && k.ToLower() != "_id"))
                {
                    <th>@key.ToUpper()</th>
                }
                <th style="width: 100px;" class="text-end">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var row = Model[i];
                var dataDict = deserializedRows.Count > i ? deserializedRows[i] : null;

                <tr>
                    @* Her zaman veritabanındaki row.Id değerini gösteren hücre *@
                    <td style="font-family: monospace; font-size: 0.85em; color: #aaa;">
                        @row.Id
                    </td>

                    @* Diğer dinamik verileri basan döngü *@
                    @foreach (var key in allKeys.Where(k => k.ToLower() != "id" && k.ToLower() != "_id"))
                    {
                        <td>
                            @if (dataDict != null && dataDict.ContainsKey(key))
                            {
                                @dataDict[key].ToString()
                            }
                            else
                            {
                                <span class="text-muted" style="font-size: 0.8em;">-</span>
                            }
                        </td>
                    }
                    <td class="text-end">
                        <form asp-action="DeleteRow" method="post" id="delete-form-@row.Id" style="display:inline;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@row.Id" />
    <input type="hidden" name="tableName" value="@tableName" />
    
    <button type="button" class="btn-icon btn-delete" onclick="confirmDelete('@row.Id')">
        <i class="fa-solid fa-trash"></i>
    </button>
</form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
                }
            </div>
        </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

document.getElementById("dynamicForm").addEventListener("submit", function (e) {
    // Formun otomatik gönderilmesini engellemiyoruz ama 
    // veriyi tam o anda hazırladığımızdan emin olmalıyız.
    const keys = document.querySelectorAll(".key-input");
    const values = document.querySelectorAll(".value-input");
    const jsonObject = {};

    keys.forEach((keyInput, index) => {
        const key = keyInput.value.trim();
        const value = values[index].value.trim();
        if (key !== "") {
            jsonObject[key] = value;
        }
    });

    const jsonString = JSON.stringify(jsonObject);
    console.log("Gönderilen JSON:", jsonString); // Hata ayıklama için
    
    document.getElementById("jsonDataInput").value = jsonString;

    // Eğer veri boşsa göndermeyi iptal etmek isterseniz:
    if (Object.keys(jsonObject).length === 0) {
        alert("Lütfen en az bir alan doldurun.");
        e.preventDefault();
        return false;
    }
});
    const fieldsContainer =
        document.getElementById("fieldsContainer");

    const inlineEditor =
                document.getElementById("inlineEditor");

            function openEditor() {

                inlineEditor.classList.add("active");

                if (fieldsContainer.children.length === 0) {

                    addField("Id", crypto.randomUUID());
                }

                setTimeout(() => {

                    inlineEditor.scrollIntoView({
                        behavior: "smooth",
                        block: "start"
                    });

                }, 100);
            }

            function closeEditor() {

                inlineEditor.classList.remove("active");
            }

            function addField(key = "", value = "") {

                const div =
                    document.createElement("div");

                div.className = "field-row";

                div.innerHTML = `

                            <div class="field-label">
                                Alan
                            </div>

                            <div class="field-grid">

                                <input type="text"
                                       class="form-modern key-input"
                                       placeholder="Alan adı"
                                       value="${key}" />

                                <input type="text"
                                       class="form-modern value-input"
                                       placeholder="Değer"
                                       value="${value}" />

                                <button type="button"
                                        class="field-remove"
                                        onclick="removeField(this)">

                                    <i class="fa-solid fa-trash"></i>

                                </button>

                            </div>

                        `;

                fieldsContainer.appendChild(div);
            }

            function removeField(button) {

                button
                    .closest(".field-row")
                    .remove();
            }

            document
                .getElementById("dynamicForm")
                .addEventListener("submit", function () {

                    const keys =
                        document.querySelectorAll(".key-input");

                    const values =
                        document.querySelectorAll(".value-input");

                    const jsonObject = {};

                    for (let i = 0; i < keys.length; i++) {

                        const key =
                            keys[i].value.trim();

                        const value =
                            values[i].value.trim();

                        if (key !== "") {

                            jsonObject[key] = value;
                        }
                    }

                    document
                        .getElementById("jsonDataInput")
                        .value =
                        JSON.stringify(jsonObject);
    });
    
    function confirmDelete(id) {
    Swal.fire({
        title: 'Emin misiniz?',
        text: "Bu veriyi sildiğinizde geri alamazsınız!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444', // Modern kırmızı tonu
        cancelButtonColor: '#64748b',  // Modern gri tonu
        confirmButtonText: 'Evet, sil!',
        cancelButtonText: 'Vazgeç',
        background: '#1e293b', // Koyu tema arka planı
        color: '#f8fafc'       // Beyaz metin rengi
    }).then((result) => {
        if (result.isConfirmed) {
            // Formu programatik olarak gönderiyoruz
            document.getElementById('delete-form-' + id).submit();
        }
    })
}
</script>

@if (TempData["SuccessMessage"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Başarılı!',
            text: '@TempData["SuccessMessage"]',
            timer: 2500,
            showConfirmButton: false,
            background: '#1e293b',
            color: '#f8fafc'
        });
    </script>
}