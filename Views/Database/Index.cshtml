@model List<string>

@{
    ViewData["Title"] = "Monobase";

    var userEmail = Context.Session.GetString("UserEmail");
    var apiKey = Context.Session.GetString("UserApiKey");

    var dbName = $"{userEmail?.Split('@')[0]}_db";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    :root {
        --bg: #0b1120;
        --card: #111827;
        --card2: #1e293b;
        --line: #243041;
        --text: #f8fafc;
        --muted: #94a3b8;
        --primary: #2563eb;
        --primaryHover: #1d4ed8;
        --success: #22c55e;
        --danger: #ef4444;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background:
            radial-gradient(circle at top left, #1e3a8a22, transparent 25%),
            radial-gradient(circle at bottom right, #2563eb22, transparent 25%),
            var(--bg);

        font-family: 'Inter', sans-serif;
        color: var(--text);
        min-height: 100vh;
    }

    .dashboard {
        padding: 40px 0;
    }

    .main-card {
        background: rgba(17, 24, 39, .9);
        border: 1px solid rgba(255, 255, 255, .05);
        backdrop-filter: blur(12px);
        border-radius: 32px;
        padding: 32px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, .35);
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        gap: 20px;
        flex-wrap: wrap;
    }

    .logo-area {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .logo-box {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 10px 30px rgba(37, 99, 235, .4);
    }

    .db-name {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .status {
        color: var(--muted);
        font-size: .95rem;
    }

    .status i {
        color: var(--success);
        margin-right: 6px;
        font-size: 10px;
    }

    .btn-primary-modern {
        border: none;
        background: linear-gradient(135deg, var(--primary), #1e40af);
        color: white;
        padding: 14px 22px;
        border-radius: 18px;
        font-weight: 600;
        transition: .2s;
        box-shadow: 0 10px 25px rgba(37, 99, 235, .25);
    }

    .btn-primary-modern:hover {
        transform: translateY(-2px);
        background: linear-gradient(135deg, var(--primaryHover), #1d4ed8);
    }

    /* Inline Add Collection Tab */
    .add-collection-tab {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(37, 99, 235, 0.3);
        border-left: 4px solid var(--primary);
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 32px;
    }

    .grid-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
    }

    @@media(max-width:992px) {
        .grid-layout {
            grid-template-columns: 1fr;
        }
    }

    .panel {
        background: rgba(15, 23, 42, .85);
        border: 1px solid rgba(255, 255, 255, .06);
        border-radius: 28px;
        overflow: hidden;
    }

    .panel-header {
        padding: 22px 24px;
        border-bottom: 1px solid rgba(255, 255, 255, .05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .panel-title {
        font-size: 1.1rem;
        font-weight: 700;
    }

    .badge-modern {
        background: #1d4ed833;
        color: #60a5fa;
        padding: 8px 14px;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 600;
    }

    .collections {
        padding: 24px;
    }

    .collection-item {
        background: rgba(255, 255, 255, .03);
        border: 1px solid rgba(255, 255, 255, .05);
        border-radius: 22px;
        padding: 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        transition: .2s;
    }

    .collection-item:hover {
        transform: translateY(-3px);
        border-color: #2563eb66;
        background: rgba(37, 99, 235, .08);
    }

    .collection-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .collection-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: #2563eb22;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #60a5fa;
        font-size: 1.2rem;
    }

    .collection-name {
        font-weight: 700;
        margin-bottom: 4px;
    }

    .collection-desc {
        color: var(--muted);
        font-size: .85rem;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
    }

    .btn-action {
        border: none;
        border-radius: 14px;
        width: 42px;
        height: 42px;
        background: #ffffff10;
        color: white;
        transition: .2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-action:hover {
        background: #2563eb;
    }

    .btn-delete:hover {
        background: var(--danger);
    }

    .side-card {
        padding: 24px;
        margin-bottom: 24px;
    }

    .api-box {
        margin-top: 18px;
        background: #00000033;
        border: 1px solid rgba(255, 255, 255, .08);
        border-radius: 18px;
        padding: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    code {
        color: #93c5fd;
        font-size: .85rem;
    }

    .cors-item {
        background: rgba(255, 255, 255, .03);
        border-radius: 18px;
        padding: 14px;
        margin-top: 16px;
        border: 1px solid rgba(255, 255, 255, .05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--success);
    }

    .empty-area {
        padding: 80px 20px;
        text-align: center;
    }

    .empty-area i {
        font-size: 4rem;
        opacity: .2;
        margin-bottom: 20px;
    }

    .empty-title {
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 10px;
    }

    .empty-sub {
        color: var(--muted);
    }

    .form-control-modern {
        background: #111827;
        border: 1px solid rgba(255, 255, 255, .08);
        border-radius: 18px;
        color: white;
        padding: 16px;
    }

    .form-control-modern:focus {
        background: #111827;
        color: white;
        border-color: #2563eb;
        box-shadow: none;
        outline: none;
    }

    .floating-alerts {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        width: 360px;
    }

    .custom-alert {
        background: #111827;
        border: 1px solid rgba(255, 255, 255, .08);
        color: white;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 14px;
        animation: slide .25s ease;
    }

    @@keyframes slide {
        from {
            opacity: 0;
            transform: translateX(50px);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    .api-key-wrapper {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-left: 20px;
        /* Logo alanından mesafe */
    }

    .api-key-label {
        font-size: 10px;
        font-weight: 800;
        color: var(--muted);
        letter-spacing: 1px;
        margin-left: 4px;
    }

    .api-key-container {
        background: var(--card2);
        border: 1px solid var(--line);
        padding: 8px 15px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
        max-width: 300px;
    }

    .api-key-container:hover {
        border-color: var(--primary);
        background: rgba(37, 99, 235, 0.1);
    }

    .api-key-container code {
        color: var(--text);
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 13px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .copy-btn {
        background: transparent;
        border: none;
        color: var(--muted);
        font-size: 14px;
        transition: color 0.2s;
    }

    .api-key-container:hover .copy-btn {
        color: var(--primary);
    }

    /* Kopyalandı Tooltip */
    .copy-tooltip {
        position: absolute;
        top: -35px;
        right: 0;
        background: var(--primary);
        color: white;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: bold;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .copy-tooltip.show {
        opacity: 1;
        visibility: visible;
        top: -40px;
    }
</style>

<div class="floating-alerts">
    @if (TempData["Success"] != null)
    {
        <div class="custom-alert">
            <i class="fa-solid fa-circle-check text-success"></i>
            <div>@TempData["Success"]</div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="custom-alert">
            <i class="fa-solid fa-circle-exclamation text-danger"></i>
            <div>@TempData["Error"]</div>
        </div>
    }
</div>

<div class="container dashboard">

    <div class="main-card">

        <div class="topbar">

            <div class="logo-area">

                <div class="logo-box">
                    <i class="fa-solid fa-database"></i>
                </div>

                <div>
                    <div class="db-name">@dbName</div>

                    <div class="status">
                        <i class="fa-solid fa-circle"></i>
                        Realtime cloud database aktif
                    </div>
                </div>

            </div>
            <div class="api-key-wrapper">
                <div class="api-key-label">API ANAHTARI</div>
                <div class="api-key-container" onclick="copyApiKey()">
                    <code id="apiKeyText">@apiKey</code>
                    <button class="copy-btn" title="Kopyala">
                        <i class="fa-solid fa-copy"></i>
                    </button>
                    <span class="copy-tooltip" id="copyTooltip">Kopyalandı!</span>
                </div>
            </div>

            <button class="btn-primary-modern" data-bs-toggle="collapse" data-bs-target="#addCollectionArea"
                    aria-expanded="false" aria-controls="addCollectionArea">

                <i class="fa-solid fa-plus me-2"></i>
                Yeni Koleksiyon

            </button>

        </div>

        <div class="collapse" id="addCollectionArea">
            <div class="add-collection-tab">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold m-0 d-flex align-items-center gap-2">
                        <i class="fa-solid fa-folder-plus text-primary"></i>
                        Yeni Koleksiyon Oluştur
                    </h5>
                    <button type="button" class="btn-action" onclick="closeCollectionMenu()">

                        <i class="fa-solid fa-xmark"></i>

                    </button>
                </div>

                <form asp-controller="Database" asp-action="AddCollection" method="post" id="collectionForm">

                    @Html.AntiForgeryToken()

                    <div class="row align-items-start">
                        <div class="col-md-8">
                            <label class="small text-uppercase fw-bold mb-2 text-muted">
                                Koleksiyon Adı
                            </label>
                            <input type="text" name="name" class="form-control form-control-modern w-100"
                                   placeholder="Örn: Kullanicilar" required maxlength="30" pattern="^[a-zA-Z0-9_]+$" />
                            <div class="text-secondary small mt-2">
                                Sadece İngilizce karakterler, sayılar ve alt çizgi kullanın.
                            </div>
                        </div>

                        <div class="col-md-4 d-flex align-items-center mt-4 pt-1">
                            <button type="submit" id="submitBtn" class="btn-primary-modern w-100">
                                <i class="fa-solid fa-plus me-2"></i>
                                Oluştur
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <div class="grid-layout">

            <div class="panel">

                <div class="panel-header">

                    <div class="panel-title">
                        Veri Koleksiyonları
                    </div>

                    <div class="badge-modern">
                        @(Model?.Count ?? 0) Koleksiyon
                    </div>

                </div>

                <div class="collections">

                    @if (Model == null || !Model.Any())
                    {
                        <div class="empty-area">

                            <i class="fa-regular fa-folder-open"></i>

                            <div class="empty-title">
                                Henüz koleksiyon yok
                            </div>

                            <div class="empty-sub">
                                İlk koleksiyonunuzu oluşturup veri depolamaya başlayın.
                            </div>

                        </div>
                    }
                    else
                    {
                        @foreach (var table in Model)
                        {
                            <div class="collection-item">

                                <div class="collection-left">

                                    <div class="collection-icon">
                                        <i class="fa-solid fa-table"></i>
                                    </div>

                                    <div>

                                        <div class="collection-name">
                                            @table
                                        </div>

                                        <div class="collection-desc">
                                            JSON / REST Collection
                                        </div>

                                    </div>

                                </div>

                                <div class="action-buttons">

                                    <a asp-action="TableDetails" asp-route-tableName="@table"
                                           class="btn-action text-decoration-none">

                                        <i class="fa-solid fa-code"></i>

                                    </a>

                                    
                                </div>

                            </div>
                        }
                    }

                </div>

            </div>

            
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

    async function copyApi() {

    const text = document.getElementById("apiText").innerText;

    try {
    await navigator.clipboard.writeText(text);
    } catch {
    alert("Kopyalanamadı");
    }
    }

    

    document.getElementById("collectionForm")
    ?.addEventListener("submit", function () {

    const btn = document.getElementById("submitBtn");

    btn.disabled = true;

    btn.innerHTML = `
    <span class="spinner-border spinner-border-sm me-2"></span>
    Oluşturuluyor
    `;
    });
    async function copyApi() {

    const text = document.getElementById("apiText").innerText;

    try {
    await navigator.clipboard.writeText(text);
    }
    catch {
    alert("Kopyalanamadı");
    }
    }

    function closeCollectionMenu() {

    const collapseEl =
    document.getElementById("addCollectionArea");

    const bsCollapse =
    bootstrap.Collapse.getOrCreateInstance(collapseEl);

    bsCollapse.hide();
    }

    document.getElementById("collectionForm")
    ?.addEventListener("submit", function () {

    const btn =
    document.getElementById("submitBtn");

    btn.disabled = true;

    btn.innerHTML = `
    <span class="spinner-border spinner-border-sm me-2"></span>
    Oluşturuluyor
    `;
    });
    async function copyApiKey() {
    const apiKey = document.getElementById("apiKeyText").innerText;
    const tooltip = document.getElementById("copyTooltip");

    try {
    await navigator.clipboard.writeText(apiKey);
        
    // Başarılı görsel geri bildirim
    tooltip.classList.add("show");
    setTimeout(() => {
    tooltip.classList.remove("show");
    }, 2000);
        
    } catch (err) {
    console.error('Kopyalama başarısız: ', err);
    alert("Kopyalanamadı!");
    }
    }

</script>