@{
    ViewData["Title"] = "Kayıt Ol";
}

<style>

    .auth-wrapper{
        min-height:75vh;
        display:flex;
        align-items:center;
        justify-content:center;
    }

    .auth-card{
        width:100%;
        max-width:520px;

        background:rgba(15,23,42,.82);
        border:1px solid rgba(255,255,255,.06);

        backdrop-filter:blur(18px);

        border-radius:34px;

        padding:38px;

        box-shadow:
            0 20px 60px rgba(0,0,0,.35);
    }

    .auth-logo{
        width:78px;
        height:78px;

        border-radius:24px;

        margin:0 auto 24px auto;

        background:linear-gradient(135deg,#2563eb,#1d4ed8);

        display:flex;
        align-items:center;
        justify-content:center;

        font-size:1.8rem;
        color:white;

        box-shadow:
            0 15px 35px rgba(37,99,235,.35);
    }

    .auth-title{
        font-size:2rem;
        font-weight:800;
        color:white;
        margin-bottom:10px;
    }

    .auth-subtitle{
        color:#94a3b8;
        font-size:.97rem;
        line-height:1.6;
    }

    .form-label{
        color:#cbd5e1;
        font-size:.92rem;
        margin-bottom:10px;
        font-weight:600;
    }

    .form-control-modern{
        background:#111827 !important;
        border:1px solid rgba(255,255,255,.07) !important;

        color:white !important;

        border-radius:18px;

        padding:16px 18px;

        font-size:.96rem;

        transition:.2s;
    }

    .form-control-modern::placeholder{
        color:#64748b;
    }

    .form-control-modern:focus{
        border-color:#2563eb !important;

        box-shadow:
            0 0 0 4px rgba(37,99,235,.12) !important;

        background:#111827 !important;
    }

    .btn-auth{
        width:100%;

        border:none;

        border-radius:18px;

        padding:16px;

        background:
            linear-gradient(135deg,#2563eb,#1d4ed8);

        color:white;

        font-weight:700;

        transition:.2s;

        box-shadow:
            0 10px 30px rgba(37,99,235,.28);
    }

    .btn-auth:hover{
        transform:translateY(-2px);
    }

    .auth-link{
        color:#60a5fa;
        text-decoration:none;
        font-weight:700;
    }

    .auth-link:hover{
        color:white;
    }

    .error-box{
        background:rgba(239,68,68,.12);

        border:1px solid rgba(239,68,68,.18);

        color:#fecaca;

        border-radius:18px;

        padding:16px;

        margin-bottom:22px;
    }

    .divider{
        height:1px;
        background:rgba(255,255,255,.05);
        margin:28px 0;
    }

    @@media(max-width:576px){

        .auth-card{
            padding:26px;
            border-radius:28px;
        }

        .auth-title{
            font-size:1.7rem;
        }
    }

</style>

<div class="auth-wrapper">

    <div class="auth-card">

        <div class="text-center">

            <div class="auth-logo">
                <i class="fa-solid fa-database"></i>
            </div>

            <h1 class="auth-title">
                Yeni Hesap Oluştur
            </h1>

            <p class="auth-subtitle">
                Monobase ile kendi modern bulut veritabanınızı
                saniyeler içinde oluşturmaya başlayın.
            </p>

        </div>

        <div class="divider"></div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">

                <i class="fa-solid fa-circle-exclamation me-2"></i>

                @ViewBag.Error

            </div>
        }

        <form asp-action="Register"
              method="post">

            <div class="mb-4">

                <label class="form-label">
                    E-Posta Adresi
                </label>

                <input type="email"
                       name="email"
                       class="form-control form-control-modern"
                       required
                       placeholder="ornek@mail.com" />

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Şifre
                </label>

                <input type="password"
                       name="password"
                       class="form-control form-control-modern"
                       required
                       placeholder="••••••••" />

            </div>

            <button type="submit"
                    class="btn-auth">

                <i class="fa-solid fa-user-plus me-2"></i>

                Kayıt Ol ve Doğrula

            </button>

        </form>

        <div class="text-center mt-4">

            <span class="text-secondary">
                Zaten hesabın var mı?
            </span>

            <a asp-action="Login"
               class="auth-link ms-1">

                Giriş Yap

            </a>

        </div>

    </div>

</div>