<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Monobase</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MonoBase.styles.css" asp-append-version="true" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml"
          href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 256 256'%3E%3Cdefs%3E%3ClinearGradient id='bg' x1='0' y1='0' x2='256' y2='256'%3E%3Cstop offset='0%25' stop-color='%233B82F6'/%3E%3Cstop offset='100%25' stop-color='%231D4ED8'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect x='16' y='16' width='224' height='224' rx='56' fill='url(%23bg)'/%3E%3Cpath d='M72 178V82L128 126L184 82V178' stroke='white' stroke-width='22' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E">

    <style>
        img{
            border-radius: 12px;
        }
        :root{
            --bg:#020617;
            --card:#0f172a;
            --card2:#111827;
            --line:rgba(255,255,255,.06);
            --text:#f8fafc;
            --muted:#94a3b8;
            --primary:#2563eb;
            --primary-hover:#1d4ed8;
        }

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            background:
                radial-gradient(circle at top left,
                rgba(37,99,235,.18),
                transparent 30%),

                radial-gradient(circle at bottom right,
                rgba(59,130,246,.14),
                transparent 30%),

                var(--bg);

            min-height:100vh;
            color:var(--text);
            font-family:'Inter',sans-serif;
            overflow-x:hidden;
        }

        a{
            text-decoration:none;
        }

        /* FLOATING BLUR */
        .blur-orb{
            position:fixed;
            border-radius:50%;
            filter:blur(80px);
            z-index:-1;
            opacity:.5;
        }

        .orb1{
            width:300px;
            height:300px;
            background:#2563eb;
            top:-100px;
            left:-100px;
        }

        .orb2{
            width:350px;
            height:350px;
            background:#1d4ed8;
            bottom:-120px;
            right:-120px;
        }

        /* NAVBAR */

        .navbar{
            padding:18px 0;
            background:rgba(15,23,42,.72) !important;
            backdrop-filter:blur(18px);
            border-bottom:1px solid rgba(255,255,255,.05);
            position:sticky;
            top:0;
            z-index:1000;
        }

        .navbar-brand{
            display:flex;
            align-items:center;
            gap:14px;
            font-weight:800;
            font-size:1.25rem;
            color:white !important;
        }

        .logo-box{
            width:48px;
            height:48px;
            border-radius:16px;
            background:linear-gradient(135deg,#2563eb,#1d4ed8);
            display:flex;
            align-items:center;
            justify-content:center;
            box-shadow:
                0 10px 30px rgba(37,99,235,.35);
        }

        .logo-box img{
            width:28px;
            height:28px;
            object-fit:contain;
        }

        .nav-link{
            color:#cbd5e1 !important;
            font-weight:500;
            border-radius:14px;
            padding:10px 16px !important;
            transition:.2s;
        }

        .nav-link:hover{
            background:rgba(37,99,235,.12);
            color:white !important;
        }

        .nav-button{
            background:linear-gradient(135deg,#2563eb,#1d4ed8);
            color:white !important;
            border-radius:14px;
            padding:10px 18px !important;
            box-shadow:
                0 8px 25px rgba(37,99,235,.25);
        }

        .nav-button:hover{
            transform:translateY(-1px);
        }

        /* MAIN */

        .page-wrapper{
            padding-top:40px;
            padding-bottom:50px;
        }

        .main-card{
            background:rgba(15,23,42,.82);
            backdrop-filter:blur(16px);
            border:1px solid rgba(255,255,255,.06);
            border-radius:34px;
            padding:32px;
            box-shadow:
                0 15px 50px rgba(0,0,0,.35);
            animation:fadeUp .45s ease;
        }

        @@keyframes fadeUp{

            from{
                opacity:0;
                transform:translateY(12px);
            }

            to{
                opacity:1;
                transform:none;
            }
        }

        /* FOOTER */

        footer{
            text-align:center;
            padding:26px;
            color:var(--muted);
            font-size:.95rem;
        }

        /* SCROLLBAR */

        ::-webkit-scrollbar{
            width:10px;
        }

        ::-webkit-scrollbar-thumb{
            background:#1e293b;
            border-radius:20px;
        }

        ::-webkit-scrollbar-track{
            background:transparent;
        }

        /* MOBILE */

        @@media(max-width:768px){

            .main-card{
                padding:20px;
                border-radius:26px;
            }

            .navbar-brand{
                font-size:1.05rem;
            }

            .logo-box{
                width:42px;
                height:42px;
            }
        }

    </style>

</head>

<body>

    <!-- BACKGROUND BLUR -->
    <div class="blur-orb orb1"></div>
    <div class="blur-orb orb2"></div>

    <!-- NAVBAR -->
    <header>

        <nav class="navbar navbar-expand-lg">

            <div class="container">

                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">

                    <div class="logo-box">

                        <img src="~/images/monobase-logo.png"
                             alt="Monobase Logo" />

                    </div>

                    Monobase

                </a>

                <button class="navbar-toggler border-0 shadow-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarMain">

                    <i class="fa-solid fa-bars text-white"></i>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarMain">

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Ana Sayfa

                            </a>
                        </li>

                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Database"
                                   asp-action="Index">

                                    Veritabanım

                                </a>

                            </li>

                          
                            <li class="nav-item">

                                <a class="nav-link nav-button"
                                   asp-controller="Auth"
                                   asp-action="Logout">

                                    <i class="fa-solid fa-arrow-right-from-bracket me-2"></i>
                                    Çıkış Yap

                                </a>

                            </li>
                        }
                        else
                        {
                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Auth"
                                   asp-action="Login">

                                    Giriş Yap

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link nav-button"
                                   asp-controller="Auth"
                                   asp-action="Register">

                                    <i class="fa-solid fa-user-plus me-2"></i>
                                    Kayıt Ol

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <!-- PAGE -->
    <div class="container page-wrapper">

        <main role="main">

            <div class="main-card">

                @RenderBody()

            </div>

        </main>

    </div>

    <!-- FOOTER -->

    <footer>

        © 2026 Monobase — Modern Cloud Database Platform

    </footer>

    <!-- JS -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>